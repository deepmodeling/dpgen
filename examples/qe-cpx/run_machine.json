{
    "deepmd_version": "3",
    "train": {
        "command": "dp",
        "machine": {
            "batch_type": "Shell",
            "context_type": "local",
            "local_root": "./",
            "remote_root": "./workflow"
        },
        "resources": {
            "batch_type": "Shell",
            "number_node": 1,
            "cpu_per_node": 1,
